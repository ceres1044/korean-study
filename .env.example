# API Keys and Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# OPENAI API (Whisper Transcription)
# ============================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# ============================================
# ANTHROPIC CLAUDE API (Text Analysis)
# ============================================
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ============================================
# NOTION API (Database Integration)
# ============================================
# Get token from: https://www.notion.com/profile/integrations
# Get database ID from URL: https://notion.so/{DATABASE_ID}?v=...
NOTION_TOKEN=ntn_your-token-here
NOTION_DATABASE_ID=your-database-id-here

# ============================================
# CLASS INFORMATION
# ============================================
# Names used in processing and logs
TEACHER_NAME=Cathy
STUDENT_NAME=Jing

# ============================================
# PROCESSING SETTINGS
# ============================================
# Auto-send to Notion immediately after analysis
# Options: true, false
AUTO_SEND_TO_NOTION=false

# Minimum confidence level for items to be included
# Options: high, medium, low
CONFIDENCE_THRESHOLD=medium
